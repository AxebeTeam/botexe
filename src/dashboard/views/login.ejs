<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MPBot Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
  <div class="login-container">
    <div class="login-card">
      <div class="login-header">
        <h1>🔐 MPBot Dashboard</h1>
        <p>Sign in to manage your bot</p>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/login" class="login-form">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required placeholder="admin">
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn btn-primary btn-block">Sign In</button>
      </form>
      <div style="text-align:center;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #2a2a4a;">
        <p style="color:#8b949e;font-size:0.85rem;margin-bottom:0.5rem;">Server owners manage your server here:</p>
        <a href="/customer/login" style="color:#5865F2;font-weight:600;">Login with Discord →</a>
      </div>
    </div>
  </div>
</body>
</html>
