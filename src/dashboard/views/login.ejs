<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - EXE Bot</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
  <div class="login-container">
    <div class="login-card">
      <div class="brand-icon">🔐</div>
      <div class="login-header">
        <h1>Admin Panel</h1>
        <p>Sign in to manage the bot</p>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/login" class="login-form">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" class="form-input" required placeholder="admin">
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" class="form-input" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">Sign In</button>
      </form>
      <div style="text-align:center;margin-top:24px;padding-top:20px;border-top:1px solid var(--border);">
        <p class="text-muted" style="font-size:12px;margin-bottom:8px;">Server owners manage your server here:</p>
        <a href="/customer/login" style="color:var(--accent);font-weight:600;font-size:13px;text-decoration:none;">Login with Discord →</a>
      </div>
    </div>
  </div>
</body>
</html>
