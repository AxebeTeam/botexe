<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - EXE Bot</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
  <div class="login-container">
    <div class="login-card">
      <div class="brand-icon">⚡</div>
      <div class="login-header">
        <h1>EXE Bot</h1>
        <p>Login with Discord to manage your servers</p>
      </div>

      <% if (query && query.error) { %>
        <div class="login-error">
          <%= query.error === 'no_code' ? 'No authorization code received.' : query.error === 'token_failed' ? 'Failed to authenticate with Discord.' : query.error === 'session_expired' ? 'Session expired. Please login again.' : 'An error occurred.' %>
        </div>
      <% } %>

      <div class="login-options">
        <a href="https://discord.com/api/oauth2/authorize?client_id=<%= CLIENT_ID %>&redirect_uri=<%= encodeURIComponent(REDIRECT_URI) %>&response_type=code&scope=identify%20guilds" class="discord-btn">
          <svg width="20" height="16" viewBox="0 0 71 55" fill="none"><path d="M60.1 4.9A58.5 58.5 0 0045.4.2a.2.2 0 00-.2.1 40.8 40.8 0 00-1.8 3.7 54 54 0 00-16.2 0A26.7 26.7 0 0025.4.3a.2.2 0 00-.2-.1A58.4 58.4 0 0010.5 4.9a.2.2 0 00-.1.1C3.7 18.4 1.9 31.7 2.8 44.8a.2.2 0 00.1.1 58.7 58.7 0 0017.7 9 .2.2 0 00.3-.1 42 42 0 003.6-5.9.2.2 0 00-.1-.3 38.7 38.7 0 01-5.5-2.6.2.2 0 01 0-.4c.4-.3.7-.6 1.1-.9a.2.2 0 01.2 0 42 42 0 0035.6 0 .2.2 0 01.2 0l1.1.9a.2.2 0 010 .4c-1.8 1-3.6 1.9-5.5 2.6a.2.2 0 00-.1.3 47.5 47.5 0 003.6 5.9.2.2 0 00.3.1 58.5 58.5 0 0017.7-9 .2.2 0 00.1-.1c1.1-15.8-.6-29.2-7.3-41.5a.2.2 0 00-.1-.2zM23.7 36.7c-3.1 0-5.7-2.9-5.7-6.4s2.5-6.4 5.7-6.4 5.7 2.8 5.7 6.4-2.6 6.4-5.7 6.4zm21.1 0c-3.1 0-5.7-2.9-5.7-6.4s2.5-6.4 5.7-6.4 5.7 2.8 5.7 6.4-2.5 6.4-5.7 6.4z" fill="currentColor"/></svg>
          Login with Discord
        </a>
      </div>
    </div>
  </div>
</body>
</html>
