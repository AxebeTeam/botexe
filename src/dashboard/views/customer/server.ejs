<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MPBot</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/sidebar', { currentPage: 'server' }) %>

    <div class="main-header">
      <div>
        <h1 style="display:flex;align-items:center;gap:.75rem;">
          <% if (guild.icon) { %><img src="<%= guild.icon %>" style="width:36px;height:36px;border-radius:50%;"><% } %>
          <%= guild.name %>
        </h1>
        <div class="breadcrumb"><%= guild.id %> / <span>Overview</span></div>
      </div>
      <div class="header-actions">
        <% if (guild.isOwner) { %><span class="badge badge-active">Owner</span><% } %>
        <span style="font-size:.82rem;color:var(--text-muted);">👥 <%= guild.memberCount %> members</span>
      </div>
    </div>

    <% if (query && query.saved) { %>
      <div class="alert alert-success">✅ Settings saved successfully!</div>
    <% } %>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-icon purple">🔑</div>
        <div class="stat-body">
          <div class="stat-value"><%= settings.has_key ? 'Active' : 'Inactive' %></div>
          <div class="stat-label">Key Status</div>
        </div>
        <span class="stat-trend <%= settings.has_key ? 'up' : 'down' %>"><%= settings.has_key ? 'Active' : 'Expired' %></span>
      </div>
      <div class="stat-card">
        <div class="stat-icon red">⚠️</div>
        <div class="stat-body">
          <div class="stat-value"><%= settings.warnCount %></div>
          <div class="stat-label">Warnings</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon orange">🎫</div>
        <div class="stat-body">
          <div class="stat-value"><%= settings.ticketCount %></div>
          <div class="stat-label">Tickets</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon blue">💰</div>
        <div class="stat-body">
          <div class="stat-value"><%= settings.econUsers %></div>
          <div class="stat-label">Economy Users</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green">📈</div>
        <div class="stat-body">
          <div class="stat-value"><%= settings.leveledUsers %></div>
          <div class="stat-label">Leveled Users</div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">🚀 Quick Actions</div>
      </div>
      <div class="server-grid" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr));">
        <a href="/customer/guild/<%= guild.id %>/commands" class="server-card" style="cursor:pointer;text-decoration:none;color:inherit;display:block;">
          <div style="font-size:2rem;margin-bottom:.5rem;">🔧</div>
          <div class="server-name">Commands</div>
          <div class="server-meta"><span>Enable/disable</span></div>
        </a>
        <a href="/customer/guild/<%= guild.id %>/tickets" class="server-card" style="cursor:pointer;text-decoration:none;color:inherit;display:block;">
          <div style="font-size:2rem;margin-bottom:.5rem;">🎫</div>
          <div class="server-name">Tickets</div>
          <div class="server-meta"><span>Configure panels</span></div>
        </a>
        <a href="/customer/guild/<%= guild.id %>/automod" class="server-card" style="cursor:pointer;text-decoration:none;color:inherit;display:block;">
          <div style="font-size:2rem;margin-bottom:.5rem;">🛡️</div>
          <div class="server-name">AutoMod</div>
          <div class="server-meta"><span>Anti-spam + filters</span></div>
        </a>
        <a href="/customer/guild/<%= guild.id %>/reaction-roles" class="server-card" style="cursor:pointer;text-decoration:none;color:inherit;display:block;">
          <div style="font-size:2rem;margin-bottom:.5rem;">🎭</div>
          <div class="server-name">Roles</div>
          <div class="server-meta"><span>Reaction + Dropdowns</span></div>
        </a>
        <a href="/customer/guild/<%= guild.id %>/suggestions" class="server-card" style="cursor:pointer;text-decoration:none;color:inherit;display:block;">
          <div style="font-size:2rem;margin-bottom:.5rem;">💡</div>
          <div class="server-name">Suggestions</div>
          <div class="server-meta"><span>Manage suggestions</span></div>
        </a>
        <a href="/customer/guild/<%= guild.id %>/protection" class="server-card" style="cursor:pointer;text-decoration:none;color:inherit;display:block;">
          <div style="font-size:2rem;margin-bottom:.5rem;">🔒</div>
          <div class="server-name">Protection</div>
          <div class="server-meta"><span>Anti-raid + bypass</span></div>
        </a>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">⚙️ General Settings</div>
      </div>
      <form method="POST" action="/customer/guild/<%= guild.id %>/save">
        <div class="form-row">
          <div class="form-group">
            <label>Language</label>
            <select name="lang" style="width:200px;">
              <option value="ar" <%= settings.lang === 'ar' ? 'selected' : '' %>>العربية</option>
              <option value="en" <%= settings.lang === 'en' ? 'selected' : '' %>>English</option>
            </select>
          </div>
          <div class="form-group">
            <label>Welcome Channel ID</label>
            <input type="text" name="welcome_channel" value="<%= settings.welcome_channel || '' %>" placeholder="Channel ID">
          </div>
        </div>
        <div class="form-group">
          <label>Welcome Message</label>
          <textarea name="welcome_message" rows="3" placeholder="Welcome {user} to {server}!"><%= settings.welcome_message || '' %></textarea>
          <div class="hint">Use {user} for mention, {server} for server name, {count} for member count</div>
        </div>
        <button type="submit" class="btn btn-primary">Save Settings</button>
      </form>
    </div>

  </main>
</div>
</body>
</html>