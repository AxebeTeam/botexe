<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MPBot</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .role-item { display:flex;align-items:center;justify-content:space-between;padding:.6rem .8rem;background:var(--bg-input);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:.5rem; }
    .role-item code { font-size:.85rem; }
  </style>
</head>
<body>
<%- include('../partials/sidebar', { currentPage: 'autorole' }) %>

    <div class="main-header">
      <div>
        <h1>🎖️ Auto Role</h1>
        <div class="breadcrumb"><%= guild.name %> / <span>Auto Role</span></div>
      </div>
    </div>

    <% if (query && query.saved) { %>
      <div class="alert alert-success">✅ Auto role settings saved!</div>
    <% } %>

    <div class="card">
      <div class="card-header">
        <div class="card-title">🎖️ Auto Role Configuration</div>
      </div>
      <p class="card-desc">Automatically assign roles to new members when they join the server.</p>

      <div class="card" style="margin-bottom:1rem;">
        <div class="card-header">
          <div class="card-title">Current Auto Roles</div>
          <span style="font-size:.8rem;color:var(--text-muted);"><%= roles.length %> roles</span>
        </div>
        <% if (roles.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">🎖️</div>
            <h3>No Auto Roles Configured</h3>
            <p>Add roles below to automatically assign them to new members.</p>
          </div>
        <% } else { %>
          <% roles.forEach(function(r) { %>
            <div class="role-item">
              <span>Role ID: <code><%= r.role_id %></code></span>
              <form method="POST" action="/customer/guild/<%= guild.id %>/autorole/remove" style="display:inline" onsubmit="return confirm('Remove this auto role?')">
                <input type="hidden" name="role_id" value="<%= r.role_id %>">
                <button type="submit" class="btn btn-sm btn-danger">Remove</button>
              </form>
            </div>
          <% }); %>
        <% } %>
      </div>

      <form method="POST" action="/customer/guild/<%= guild.id %>/autorole/add">
        <div class="form-group">
          <label>Role ID to Add</label>
          <input type="text" name="role_id" class="form-input" placeholder="Paste the role ID" required>
        </div>
        <button type="submit" class="btn btn-primary">Add Auto Role</button>
      </form>
    </div>

  </main>
</div>
</body>
</html>
