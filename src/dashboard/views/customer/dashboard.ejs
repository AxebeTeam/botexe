<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - EXE Bot</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<a href="https://discord.com/oauth2/authorize?client_id=<%= CLIENT_ID %>&permissions=8&scope=bot%20applications.commands" target="_blank" class="add-bot-fixed">
  ➕ Add Bot
</a>

<%- include('../partials/sidebar', { currentPage: 'dashboard' }) %>

<div class="main-header">
  <div>
    <h1>Dashboard</h1>
    <div class="breadcrumb">Overview / <span>My Servers</span></div>
  </div>
  <div class="header-actions">
    <span class="badge badge-success">🟢 Online</span>
    <span class="text-muted" style="font-size:12px;"><%= guilds.length %> servers</span>
  </div>
</div>

<div class="stats-row">
  <div class="stat-card">
    <div class="stat-icon purple">📊</div>
    <div class="stat-body">
      <div class="stat-value"><%= allGuilds.length %></div>
      <div class="stat-label">Total Servers</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue">🤖</div>
    <div class="stat-body">
      <div class="stat-value"><%= guilds.length %></div>
      <div class="stat-label">Bot Added</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green">👑</div>
    <div class="stat-body">
      <div class="stat-value"><%= allGuilds.filter(g => g.hasAdmin).length %></div>
      <div class="stat-label">Admin Servers</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon orange">⚠️</div>
    <div class="stat-body">
      <div class="stat-value"><%= allGuilds.filter(g => g.hasAdmin && !g.hasBot).length %></div>
      <div class="stat-label">Need Bot</div>
    </div>
  </div>
</div>

<% if (allGuilds.filter(g => g.hasAdmin && !g.hasBot).length > 0) { %>
  <div class="card" style="border-left:3px solid var(--orange);">
    <div class="card-header">
      <div class="card-title" style="color:var(--orange);">➕ Add Bot to Your Servers</div>
      <span class="text-muted" style="font-size:12px;"><%= allGuilds.filter(g => g.hasAdmin && !g.hasBot).length %> servers</span>
    </div>
    <div class="card-desc">Servers where you have admin but the bot isn't added yet.</div>
    <div class="server-grid">
      <% allGuilds.filter(g => g.hasAdmin && !g.hasBot).forEach(g => { %>
        <a href="https://discord.com/oauth2/authorize?client_id=<%= CLIENT_ID %>&guild_id=<%= g.id %>&permissions=8&scope=bot%20applications.commands" target="_blank" class="server-card server-card-no-bot">
          <div class="add-overlay">Add Bot</div>
          <div class="server-icon">
            <% if (g.icon) { %><img src="<%= g.icon %>" alt=""><% } else { %><%= g.name.charAt(0) %><% } %>
          </div>
          <div class="server-name"><%= g.name %></div>
          <div class="server-meta">
            <% if (g.owner) { %><span class="badge badge-active">Owner</span><% } else { %><span class="badge badge-warning">Admin</span><% } %>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
<% } %>

<% if (guilds.length > 0) { %>
  <div class="card">
    <div class="card-header">
      <div class="card-title">📋 My Servers</div>
      <span class="text-muted" style="font-size:12px;"><%= guilds.length %> total</span>
    </div>
    <div class="server-grid">
      <% guilds.forEach(g => { %>
        <a href="/customer/guild/<%= g.id %>" class="server-card">
          <div class="server-icon">
            <% if (g.icon) { %><img src="<%= g.icon %>" alt=""><% } else { %><%= g.name.charAt(0) %><% } %>
          </div>
          <div class="server-name"><%= g.name %></div>
          <div class="server-meta">
            <span>👥 <%= g.memberCount || '?' %></span>
            <% if (g.owner) { %><span class="badge badge-active">Owner</span><% } %>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
<% } %>

</main>
</div>
</body>
</html>
